{% comment %}
  Unified interests entry renderer for both formats
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="interest-item">
      <div class="interest-name">
        {% if entry.icon %}
          <i class="{{ entry.icon }} interest-icon"></i>
        {% endif %}
        <strong>{{ entry.name }}</strong>
      </div>
      {% if entry.keywords %}
        <div class="interest-keywords">
          {% for keyword in entry.keywords %}
            <span class="badge interest-badge">{{ keyword }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .interest-item {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--global-divider-color, #eaecef);
  }
  .interest-item:last-child {
    border-bottom: none;
  }
  .interest-name {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }
  .interest-icon {
    margin-right: 0.4rem;
    color: var(--global-theme-color, #b509ac);
  }
  .interest-keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .interest-badge {
    background-color: var(--global-theme-color, #b509ac);
    color: #fff;
    font-weight: 400;
    padding: 0.35em 0.7em;
    border-radius: 999px;
    font-size: 0.8rem;
  }
</style>
